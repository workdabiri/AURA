# =============================================================================
# AURA — Environment Variables (EXAMPLE / TEMPLATE)
# =============================================================================
# Copy this file to `.env.local` for local development and fill in real values.
# NEVER commit a real `.env` or `.env.local`. Every value below is a PLACEHOLDER
# only — no real secrets, keys, or tokens belong in this file.
#
# Validation: see `src/lib/validation/env.schema.ts`.
#   - Public vars  -> `src/lib/config/env.public.ts` (getPublicEnv)
#   - Server vars  -> `src/lib/config/env.ts`        (getServerEnv, server-only)
# =============================================================================

# -----------------------------------------------------------------------------
# PUBLIC (client-safe)
# -----------------------------------------------------------------------------
# Inlined into the browser bundle by Next.js. SAFE to expose to the client.
# NEVER place a secret in any NEXT_PUBLIC_* variable.

# [required] Supabase project URL
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# [required] Supabase anon/public key (RLS-gated; not a secret)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# [required] Canonical public site origin
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# [optional] Enable Vercel Analytics. Accepted: true | false | 1 | 0 (default: false)
NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED="false"

# -----------------------------------------------------------------------------
# SERVER-ONLY (NEVER exposed to the client bundle)
# -----------------------------------------------------------------------------
# Read only through `src/lib/config/env.ts` (guarded by `server-only`).
# Store production values in Vercel encrypted environment storage.

# [required] Supabase service-role key — BYPASSES Row-Level Security. Server only.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# [required] Salt for rate-limit key hashing: salted-hash(IP + route) (D-51).
# Use a long, random, high-entropy value. Never store raw IPs.
RATE_LIMIT_SALT="generate-a-long-random-string"

# [optional] Resend API key for transactional email (wired in Phase 3)
RESEND_API_KEY="your-resend-api-key"

# [optional] Verified "from" address for outbound email (wired in Phase 3)
RESEND_FROM_EMAIL="no-reply@example.com"

# [optional] Recipient for new-lead notifications (Q-06; single email for MVP)
ADMIN_NOTIFICATION_EMAIL="admin@example.com"

# [optional] Sentry auth token for source-map upload at build time (Phase 6)
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
